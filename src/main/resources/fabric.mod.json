{
  "schemaVersion": 1,
  "id": "minihex",
  "version": "${version}",
  "name": "minihex",
  "description": "A Hexcasting addon with minigame-oriented spells.",
  "authors": [
    "IridescentVoid"
  ],
  "contact": {
    "homepage": "https://github.com/IridescentVoid/minihex",
    "sources": "https://github.com/IridescentVoid/minihex",
    "issues": "https://github.com/IridescentVoid/minihex/issues"
  },
  "license": "CC-BY-NC-SA 4.0",
  "icon": "assets/minihex/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "ivoid.minihex.Minihex",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "ivoid.minihex.MinihexClient",
        "adapter": "kotlin"
      }
    ],
    "fabric-datagen": [
      {
        "value": "ivoid.minihex.MinihexDataGenerator",
        "adapter": "kotlin"
      }
    ],
    "cardinal-components": [
      {
        "value": "ivoid.minihex.inits.MinihexComponents",
        "adapter": "kotlin"
      }
    ]
  },
  "accessWidener": "minihex.classtweaker",
  "mixins": [
    "minihex.mixins.json",
    {
      "config": "minihex.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "hexcasting": ">=0.11.3",
    "cardinal-components-base": "5.2.3",
    "cardinal-components-entity": "5.2.3"
  },
  "recommends": {
    "moreiotas": ">=0.1.1",
    "hexpose": ">=2.0.0",
    "hexical": ">=1.5.0",
    "xaerominimap": ">=25.3.10",
    "xaeroworldmap": ">=1.40.11"
  },
  "custom": {
    "cardinal-components": [
      "minihex:personal_modifiers"
    ]
  }
}
